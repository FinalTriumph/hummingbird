<div class="content-wrapper">
  <div class="content">
    <form class="translation-edit" method="post" action="/api/translations/update/">
      <p class="main-title">Edit translation</p>
      <div class="input-group">
        <div class="translation-group">
          <div class="title">
            <p >Key (should start with "t:", for example "t:Home")</p>
          </div>
          <input type="text" name="key" required/>
        </div>
        <div class="translation-group">
          <div class="title">
            <p>Translations</p>
          </div>
          <span class="lang">EN</span><textarea name="translations[en]" rows="2" required></textarea><br />
          <span class="lang">DE</span><textarea name="translations[de]" rows="2" required></textarea><br />
          <span class="lang">LV</span><textarea name="translations[lv]" rows="2" required></textarea><br />
          <span class="lang">RU</span><textarea name="translations[ru]" rows="2" required></textarea>
        </div>
      </div>
      <input class="btn-style-2" type="submit" value="Submit" />
    </form>
  </div>
</div>
